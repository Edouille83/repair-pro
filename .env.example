# ===========================================
# REPAIR PRO - Configuration d'environnement
# ===========================================

# ===========================================
# BASE DE DONNÉES
# ===========================================

# Développement local (SQLite)
DATABASE_URL="file:./dev.db"

# Production (Neon/Supabase PostgreSQL) - Décommenter et configurer
# DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ===========================================
# AUTHENTIFICATION
# ===========================================

# Mot de passe pour accéder à l'application (à changer en production)
AUTH_PASSWORD="admin123"

# Secret pour les sessions (générer avec: openssl rand -base64 32)
AUTH_SECRET="change-this-to-a-random-secret-in-production"

# ===========================================
# SMS - Twilio
# ===========================================

# Obtenir ces identifiants sur https://www.twilio.com/console
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_auth_token_here"
# TWILIO_PHONE_NUMBER="+33XXXXXXXXX"

# ===========================================
# EMAIL - Resend
# ===========================================

# Obtenir une clé API sur https://resend.com/api-keys
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# Email d'envoi (doit être configuré dans Resend)
# EMAIL_FROM="Repair Pro <noreply@votre-domaine.com>"

# ===========================================
# NOTES DE DÉPLOIEMENT
# ===========================================

# 1. SQLite pour développement local uniquement
# 2. Pour la production, utiliser PostgreSQL (ex: Neon, Supabase)
# 3. Configurer Twilio et Resend pour activer les notifications
# 4. Changer AUTH_PASSWORD et AUTH_SECRET en production
# 5. Déployer sur Vercel, Railway, ou autre hébergeur compatible Node.js
